# Postgres
# Inside containers: POSTGRES_HOST=postgres, POSTGRES_PORT=5432
# On Windows host with native postgres: use port 5433 (see docker-compose.override.yml)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pdm
POSTGRES_PASSWORD=pdm
POSTGRES_DB=pdm

# MinIO / S3-compatible
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_ARTIFACTS=mlflow-artifacts

# Logging
LOG_LEVEL=INFO

# Simulator
INGEST_INTERVAL_SEC=5
